---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---
<BaseLayout locale="en" title="Page not found" description="The requested page could not be found." noindex canonical={false}>
  <SiteHeader locale="en" />
  <main class="not-found"><p>404 · SIGNAL LOST</p><h1>Page not found.</h1><a href="/en/">Return to the control plane →</a></main>
</BaseLayout>
<style>.not-found{width:min(900px,calc(100% - 48px));margin:15vh auto}.not-found p{font:500 11px var(--mono);color:var(--rust)}.not-found h1{font:600 clamp(4rem,10vw,8rem)/.9 var(--serif)}.not-found a{font:500 12px var(--mono);text-transform:uppercase}</style>
