---
import type { Locale } from '../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = locale === 'en'
  ? { label: 'Theme', light: 'Light', dark: 'Dark', toLight: 'Switch to light theme', toDark: 'Switch to dark theme' }
  : { label: 'Tema', light: 'Claro', dark: 'Oscuro', toLight: 'Cambiar al tema claro', toDark: 'Cambiar al tema oscuro' };
---
<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  data-light-label={copy.light}
  data-dark-label={copy.dark}
  data-to-light={copy.toLight}
  data-to-dark={copy.toDark}
  aria-label={copy.toDark}
  aria-pressed="false"
  title={copy.toDark}
>
  <span class="theme-icon" aria-hidden="true">
    <svg class="sun-icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.5"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
    <svg class="moon-icon" viewBox="0 0 24 24"><path d="M20.4 15.2A8.5 8.5 0 0 1 8.8 3.6 8.5 8.5 0 1 0 20.4 15.2Z"/></svg>
  </span>
  <span><span class="theme-copy-label">{copy.label}: </span><span data-theme-name>{copy.light}</span></span>
</button>
<script is:inline>
  (() => {
    const button = document.currentScript?.previousElementSibling;
    if (!(button instanceof HTMLButtonElement)) return;

    const media = window.matchMedia('(prefers-color-scheme: dark)');
    const sync = () => {
      const explicit = document.documentElement.dataset.theme;
      const dark = explicit ? explicit === 'dark' : media.matches;
      const name = button.querySelector('[data-theme-name]');
      const action = dark ? button.dataset.toLight : button.dataset.toDark;
      button.dataset.mode = dark ? 'dark' : 'light';
      button.setAttribute('aria-pressed', String(dark));
      button.setAttribute('aria-label', action ?? '');
      button.title = action ?? '';
      if (name) name.textContent = dark ? button.dataset.darkLabel ?? '' : button.dataset.lightLabel ?? '';
      const themeColor = document.querySelector('meta[name="theme-color"]');
      themeColor?.setAttribute('content', dark ? '#111713' : '#f2f0e8');
    };

    button.addEventListener('click', () => {
      const dark = button.dataset.mode === 'dark';
      const next = dark ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch {}
      sync();
    });
    const handleSystemThemeChange = () => {
      if (!document.documentElement.dataset.theme) sync();
    };
    if (typeof media.addEventListener === 'function') media.addEventListener('change', handleSystemThemeChange);
    else media.addListener(handleSystemThemeChange);
    sync();
  })();
</script>
