---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';
import { content, site, type Locale } from '../data/site';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = content[locale];
---
<BaseLayout locale={locale} title={t.title} description={t.description} alternatePath={t.alternatePath}>
  <a class="skip-link" href="#main">{t.skip}</a>
  <SiteHeader locale={locale} home languageHref={t.alternatePath} languageLabel={t.alternateLabel} />

  <main id="main">
    <section class="hero wrap section-grid">
      <div class="section-label"><span>00</span><span>{t.availability}</span></div>
      <div class="hero-copy">
        <p class="eyebrow">{t.eyebrow}</p>
        <h1>{t.hero}</h1>
        <p class="lede">{t.intro}</p>
        <div class="actions">
          <a class="button primary" href={site.linkedin} target="_blank" rel="noreferrer">{t.connect}<span aria-hidden="true">↗</span></a>
          <a class="text-link" href={site.email}>{t.email}<span aria-hidden="true">↗</span></a>
          <a class="text-link" href="#impact">{t.explore}<span aria-hidden="true">↓</span></a>
        </div>
      </div>
    </section>

    <section class="proof wrap section-grid" aria-labelledby="proof-title">
      <div class="section-label"><span>01</span><span id="proof-title">{t.proofLabel}</span></div>
      <div>
        <div class="metrics">
          {t.metrics.map((metric) => <article class="metric"><strong>{metric.value}</strong><h2>{metric.label}</h2><p>{metric.detail}</p></article>)}
        </div>
        <p class="fine-print">{t.confidentiality}</p>
      </div>
    </section>

    <section id="approach" class="thesis wrap section-grid">
      <div class="section-label"><span>02</span><span>{t.nav.thesis}</span></div>
      <div>
        <div class="section-heading"><h2>{t.thesisTitle}</h2><p>{t.thesisIntro}</p></div>
        <ol class="control-plane">
          {t.chain.map((item) => <li><span class="step">{item.step}</span><div><h3>{item.title}</h3><p>{item.text}</p></div></li>)}
        </ol>
      </div>
    </section>

    <section id="impact" class="impact wrap section-grid">
      <div class="section-label"><span>03</span><span>{t.impactEyebrow}</span></div>
      <div>
        <div class="section-heading"><h2>{t.impactTitle}</h2></div>
        <div class="impact-list">
          {t.impacts.map((item) => <article class="impact-card"><div class="card-meta"><span>{item.index}</span><span>{item.tag}</span></div><h3>{item.title}</h3><p>{item.text}</p><strong>{item.result}</strong></article>)}
        </div>
      </div>
    </section>

    <section id="lab" class="lab wrap section-grid">
      <div class="section-label"><span>04</span><span>{t.labEyebrow}</span></div>
      <div class="lab-list">
        {t.labs.map((lab) => (
          <article class="lab-card" aria-labelledby={`lab-title-${lab.id}`}>
            <div class="lab-top"><span class="status"><i aria-hidden="true"></i>{lab.status}</span><span>{lab.areas}</span></div>
            <h2 id={`lab-title-${lab.id}`}>{lab.title}</h2><p>{lab.text}</p>
            <a class="button dark" href={lab.href} target="_blank" rel="noreferrer" aria-label={lab.linkLabel}>{lab.cta}<span aria-hidden="true">↗</span></a>
          </article>
        ))}
      </div>
    </section>

    <section id="about" class="story wrap section-grid">
      <div class="section-label"><span>05</span><span>{t.storyEyebrow}</span></div>
      <div class="story-grid">
        <div><h2>{t.storyTitle}</h2><p>{t.storyText}</p></div>
        <div class="human">
          <div class="profile-portrait">
            <img src="/avatar.jpg" alt="Portrait of Jesús Posada" width="1812" height="1929" loading="lazy" decoding="async" />
          </div>
          <h3>{t.humanTitle}</h3><p>{t.humanText}</p>
        </div>
      </div>
    </section>
  </main>

  <footer id="contact" class="footer">
    <div class="wrap section-grid">
      <div class="section-label"><span>06</span><span>{locale === 'en' ? 'CONTACT' : 'CONTACTO'}</span></div>
      <div><h2>{t.footerTitle}</h2><p>{t.footerText}</p><div class="actions"><a class="button primary" href={site.linkedin} target="_blank" rel="noreferrer">{t.connect}<span aria-hidden="true">↗</span></a><a class="text-link light" href={site.github} target="_blank" rel="noreferrer">{t.github}<span aria-hidden="true">↗</span></a><a class="text-link light" href={site.email}>{t.email}<span aria-hidden="true">↗</span></a></div></div>
    </div>
    <div class="wrap footer-bottom"><span>© {new Date().getFullYear()} {site.shortName}</span><span>SRE · Spain / Global</span></div>
  </footer>
</BaseLayout>
