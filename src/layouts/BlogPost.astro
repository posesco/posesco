---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { site } from '../data/site';
const { frontmatter } = Astro.props;
const tags = String(frontmatter.tags ?? 'SRE, automatización y tecnología')
  .split(',')
  .map((tag) => tag.trim())
  .filter(Boolean);
const topics = tags.join(', ');
const description = frontmatter.description ?? `Artículo de Jesús Posada sobre ${topics}.`;
const canonical = new URL(Astro.url.pathname, site.url);
const datePublished = String(frontmatter.date).split('/').reverse().join('-');
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description,
  datePublished,
  inLanguage: 'es',
  keywords: tags,
  url: canonical.href,
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${canonical.href}#webpage` },
  isPartOf: { '@id': new URL('/#website', site.url).href },
  author: { '@id': new URL('/#person', site.url).href },
};
const blogPostingJsonLd = JSON.stringify(blogPostingSchema).replace(/</g, '\\u003c');
---
<BaseLayout locale="es" title={frontmatter.title} description={description} ogType="article" publishedTime={datePublished} articleTags={tags}>
  <script is:inline type="application/ld+json" set:html={blogPostingJsonLd} />
  <a class="skip-link" href="#article">Saltar al artículo</a>
  <SiteHeader locale="es" blog />
  <main id="article" class="article-shell wrap">
    <p class="article-meta">NOTA · {frontmatter.date} · {frontmatter.read_time}</p>
    <h1>{frontmatter.title}</h1>
    <div class="article-tags">{tags.map((tag) => <span>{tag}</span>)}</div>
    <article class="prose"><slot /></article>
    <a class="article-back" href="/blog/">← Volver a todas las notas</a>
  </main>
</BaseLayout>
<style>
  .article-back{font:500 11px var(--mono);text-transform:uppercase;text-underline-offset:5px}
  .article-shell{max-width:860px;padding-block:90px 120px}.article-meta{color:var(--green);font:500 11px var(--mono);letter-spacing:.08em}
  .article-shell h1{font-size:clamp(3rem,8vw,6.5rem)}.article-tags{display:flex;flex-wrap:wrap;gap:8px;margin:30px 0 60px}.article-tags span{padding:5px 9px;border:1px solid var(--line);font:500 10px var(--mono);text-transform:uppercase}
  .prose{font-size:1.08rem}.prose :global(h1){font:600 2.7rem/1.05 var(--serif);margin-top:70px}.prose :global(h2){font:600 2.2rem/1.1 var(--serif);margin:60px 0 20px}.prose :global(h3){font:600 1.5rem var(--serif);margin-top:45px}.prose :global(p),.prose :global(li){color:var(--body-text)}.prose :global(a){color:var(--green);text-underline-offset:4px}.prose :global(img){max-width:100%;height:auto}.prose :global(pre){overflow:auto;padding:22px;background:var(--code-bg);color:var(--code-text)}.prose :global(code){font-family:var(--mono);font-size:.9em}.prose :global(blockquote){margin-inline:0;padding-left:24px;border-left:3px solid var(--green)}.prose :global(table){display:block;overflow:auto;width:100%;border-collapse:collapse}.prose :global(td),.prose :global(th){padding:10px;border:1px solid var(--line)}.article-back{display:inline-block;margin-top:80px}
</style>
